#!/usr/bin/env bash
set -euo pipefail

BACKUP_BASE="/root"
TARGET_DIR="/etc/nginx"
CMD="${1:-}"

usage() {
  cat <<'EOF'
Use:
  restore-nginx list
  restore-nginx latest
  restore-nginx YYYY-MM-DD
  restore-nginx nginx-backup-YYYY-MM-DD-HHMMSS
  restore-nginx /complete/path/to/backup

Examples:
  restore-nginx list
  restore-nginx latest
  restore-nginx 2026-01-23
  restore-nginx nginx-backup-2026-01-23-123456
  restore-nginx /root/nginx-backup-2026-01-23-123456/etc/nginx
EOF
  exit 1
}

list_backups() {
  find "$BACKUP_BASE" -maxdepth 1 -type d -name 'nginx-backup-*' | sort
}

resolve_backup_dir() {
  local input="$1"

  if [[ "$input" = /* ]]; then
    echo "$input"
    return 0
  fi

  if [[ "$input" =~ ^[0-9]{4}-[0-9]{2}-[0-9]{2}$ ]]; then
    local latest_for_day
    latest_for_day="$(find "$BACKUP_BASE" -maxdepth 1 -type d -name "nginx-backup-${input}-*" | sort | tail -n1 || true)"
    if [ -n "$latest_for_day" ]; then
      echo "$latest_for_day/etc/nginx"
      return 0
    fi
    return 1
  fi

  if [ -d "${BACKUP_BASE}/${input}/etc/nginx" ]; then
    echo "${BACKUP_BASE}/${input}/etc/nginx"
    return 0
  fi

  return 1
}

validate_backup_dir() {
  local dir="$1"

  if [ ! -d "$dir" ]; then
    echo "Backup does not exist: $dir"
    exit 1
  fi

  if [ ! -f "$dir/nginx.conf" ]; then
    echo "Backup does not look like a complete /etc/nginx (nginx.conf missing): $dir"
    exit 1
  fi
}

restore_backup() {
  local src="$1"

  validate_backup_dir "$src"

  local now
  now="$(date +%F-%H%M%S)"
  local safety="${BACKUP_BASE}/nginx-restore-safety-${now}"

  echo "Creating safety backup of current state in: $safety"
  mkdir -p "$safety"
  cp -a "$TARGET_DIR" "$safety/"

  echo "Restoring complete nginx from: $src"

  local tmp_restore
  tmp_restore="$(mktemp -d)"

  cp -a "$src/." "$tmp_restore/"

  rm -rf "${TARGET_DIR:?}/"*
  cp -a "$tmp_restore/." "$TARGET_DIR/"

  rm -rf "$tmp_restore"

  echo "Validating configuration..."
  nginx -t

  echo "Reloading nginx..."
  systemctl reload nginx

  echo "Nginx restoration completed successfully."
}

latest_backup() {
  local latest
  latest="$(find "$BACKUP_BASE" -maxdepth 2 -type f -path '*/etc/nginx/nginx.conf' -printf '%T@ %h\n' 2>/dev/null \
    | sort -nr \
    | head -n1 \
    | cut -d' ' -f2- || true)"

  if [ -n "$latest" ]; then
    echo "$latest"
    return 0
  fi

  return 1
}

case "${CMD:-}" in
  list)
    list_backups
    ;;
  latest)
    dir="$(latest_backup || true)"
    if [ -z "${dir:-}" ]; then
      echo "Could not find any valid backup."
      exit 1
    fi
    restore_backup "$dir"
    ;;
  ""|-h|--help|help)
    usage
    ;;
  *)
    dir="$(resolve_backup_dir "$CMD" || true)"
    if [ -z "${dir:-}" ]; then
      echo "Could not resolve backup for: $CMD"
      exit 1
    fi

    if [ -d "$dir/etc/nginx" ]; then
      dir="$dir/etc/nginx"
    fi

    restore_backup "$dir"
    ;;
esac
